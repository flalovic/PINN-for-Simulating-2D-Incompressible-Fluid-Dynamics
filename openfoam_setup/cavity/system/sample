FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      sample;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

type surfaces;
libs            (sampling);
interpolationScheme cellPoint;
surfaceFormat   csv;

surfaces
(
    zPlane
    {
        type            plane;
        planeType       pointAndNormal;
        pointAndNormalDict
        {
            point           (0 0 0.05);
            normalVector    (0 0 1);
        }
        interpolate     true;
    }
);

fields          (p U);
